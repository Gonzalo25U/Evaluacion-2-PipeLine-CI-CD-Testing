# ── Docker Hub ───────────────────────────────────────────────────────────────
DOCKERHUB_USERNAME=tu-usuario-dockerhub

# ── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=cambia_esto
MYSQL_DATABASE=citt_db
MYSQL_USER=citt_user
MYSQL_PASSWORD=cambia_esto

# ── Conexión backend a MySQL ─────────────────────────────────────────────────
# En desarrollo local usar "mysql" (nombre del servicio en docker-compose)
# En producción usar la IP privada de EC2 data
DB_ENDPOINT=mysql
DB_PORT=3306
DB_NAME=citt_db
DB_USERNAME=citt_user
DB_PASSWORD=cambia_esto
